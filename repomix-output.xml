:root {
  --radius: 0.625rem;
  /* Base color - all other colors are relative to this */
  --primary: oklch(0.696 0.17 162.48);

  /* Backgrounds & Surfaces (achromatic - no chroma) */
  /* --background: oklch(from var(--primary) calc(l + 0.304) 0 0); */
  --background: oklch(1 0 0);
  --foreground: oklch(from var(--primary) calc(l - 0.551) 0 0);
  --card: oklch(from var(--primary) calc(l + 0.304) 0 0);
  --card-foreground: oklch(from var(--primary) calc(l - 0.551) 0 0);
  --popover: oklch(from var(--primary) calc(l + 0.304) 0 0);
  --popover-foreground: oklch(from var(--primary) calc(l - 0.551) 0 0);
  --background-alt: oklch(0.985 0.002 247.85);

  /* Primary variants */
  --primary-foreground: oklch(from var(--primary) calc(l + 0.289) 0 0);
  --secondary: oklch(
    from var(--primary) calc(l - 0.1) calc(c - 0.025) calc(h + 0.745)
  );
  --secondary-foreground: oklch(from var(--primary) calc(l + 0.289) 0 0);
  --accent: oklch(
    from var(--primary) calc(l + 0.069) calc(c - 0.01) calc(h + 0.745)
  );
  --accent-foreground: oklch(from var(--primary) calc(l - 0.551) 0 0);

  /* Muted colors */
  --muted: oklch(from var(--primary) calc(l + 0.274) 0 0);
  --muted-foreground: oklch(from var(--primary) calc(l - 0.14) 0 0);

  /* Destructive (red/orange hue shift) */
  --destructive: oklch(0.577 0.245 27.325);
  --destructive-foreground: oklch(0.35 0.18 27);

  /* Success (green - hue ~142) */
  --success: oklch(0.925 0.04 142);
  --success-foreground: oklch(0.35 0.12 142);

  /* Info (blue - hue ~240) */
  --info: oklch(0.95 0.035 240);
  --info-foreground: oklch(0.35 0.15 240);

  /* Warning (yellow/amber - hue ~85) */
  --warning: oklch(0.95 0.06 85);
  --warning-foreground: oklch(0.35 0.12 60);

  /* Auth layout gradient (relative to primary) */
  --auth-gradient-from: oklch(from var(--primary) calc(l + 0.289) 0 0);
  --auth-gradient-via: oklch(from var(--primary) calc(l + 0.304) 0 0);
  --auth-gradient-to: oklch(
    from var(--primary) calc(l + 0.274) calc(c - 0.12) h
  );

  /* Circle track for SVG (relative to primary) */
  --circle-track: oklch(from var(--primary) calc(l + 0.224) 0 0);

  /* Left panel gradient end color (relative to primary) */
  --left-panel-gradient-to: oklch(
    from var(--primary) calc(l - 0.15) calc(c + 0.02) h
  );
  /* Light text on primary gradient */
  --left-panel-text-muted: oklch(
    from var(--primary) calc(l + 0.35) calc(c - 0.08) h
  );

  /* Borders & Inputs */
  --border: oklch(from var(--primary) calc(l + 0.226) 0 0);
  --input: oklch(from var(--primary) calc(l + 0.226) 0 0);
  --ring: var(--primary);

  /* Charts (various hue shifts) */
