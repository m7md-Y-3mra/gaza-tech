        {bookmarkedListings.map((listing) => (
          <ProfileListingCard
            key={listing.listing_id}
            listing={listing}
            isOwner={false}
          />
        ))}
      </div>
      <ProfilePagination totalCount={bookmarkedCount} pageSize={pageSize} />
    </>
  );
};

export default ProfileBookmarkTabClient;
