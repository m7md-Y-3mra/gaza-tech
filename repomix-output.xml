  --sidebar-foreground: oklch(from var(--primary) calc(l - 0.551) 0 0);
  --sidebar-primary: var(--primary);
  --sidebar-primary-foreground: oklch(from var(--primary) calc(l + 0.289) 0 0);
  --sidebar-accent: oklch(from var(--primary) calc(l + 0.274) 0 0);
