const activeFilters = [
  { id: 1, label: 'Price: $500 - $1000' },
  { id: 2, label: 'Condition: New' },
  { id: 3, label: 'Location: Gaza City' },
];

const ActiveFilters: FC<ActiveFiltersProps> = ({ searchParams }) => {
